{
  "name": "last-gasp-desktop",
  "version": "1.0.0",
  "description": "Last Gasp Desktop App",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run build:main && concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && npm run build:main",
    "package": "npm run build && electron-builder build -mwl",
    "package:win": "npm run build && electron-builder build -w"
  },
  "build": {
    "appId": "com.lastgasp.desktop",
    "productName": "Last Gasp",
    "publish": [
      {
        "provider": "github",
        "owner": "lpendrake",
        "repo": "last-gasp"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.8",
    "wait-on": "^7.2.0"
  }
}
